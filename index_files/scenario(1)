function getEventTemplate(event) {
    const [actor, action, object] = event.split(".");
    return {
        event: event || "-",
        [actor]: {
            [action]: {
                [object]: {
                    type: "pgforsta",
                    code: SURVEY_ID,
                    kind: KIND,
                    version: PROGRAM_ID + "-" + VERSION
                }
            }
