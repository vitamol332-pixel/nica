  var el = this.api.lastClicked;
  if (!el) {return null;}

  // Find closest parent card: [data-testid="iwg-narrow-card"]
  var card = el;
  while (card && card.nodeType === 1) {
    if (
      card.getAttribute &&
      card.getAttribute('data-testid') === 'iwg-narrow-card'
    ) {
      break;
    }
    card = card.parentNode;
  }

  if (!card || !card.getAttribute || card.getAttribute('data-testid') !== 'iwg-narrow-card') {
    return null;
  }

  // From that card, find the pot amount element
  var potEl = card.querySelector('[data-testid="pot-amount"]');
  var gameName = potEl && potEl.textContent ? potEl.textContent.trim() : null;

  // Carousel position (1-based index), same as before
  var slideEl = card;
  while (slideEl && slideEl.tagName !== 'LI') {
    slideEl = slideEl.parentNode;
  }

  var position = null;
  if (slideEl && slideEl.parentNode) {
    var slides = slideEl.parentNode.children;
    for (var i = 0; i < slides.length; i++) {
      if (slides[i] === slideEl) {
        position = i + 1;
        break;
      }
    }
  }

  return {
    name: gameName,
    placement: String(position)
  };

} catch (e) {
  return null;
